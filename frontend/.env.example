# Public — exposed to browser via NEXT_PUBLIC_ prefix
NEXT_PUBLIC_STREAM_API_KEY=

# Server-only — never sent to browser. Used by /api/session to mint user JWTs.
STREAM_API_SECRET=

# URL of the Python agent (Vision-Agents serve mode).
# Local dev:  http://localhost:8000
# Production: https://ergo-agent-xxxx.onrender.com
AGENT_BACKEND_URL=http://localhost:8000

# Stream call type. Default works unless you've created a custom call type
# in your Stream dashboard.
STREAM_CALL_TYPE=default
