# Stream — Video & Audio app credentials (https://getstream.io)
STREAM_API_KEY=
STREAM_API_SECRET=

# OpenAI — Realtime API for voice + tool calling
OPENAI_API_KEY=

# OpenRouter — multimodal LLM for the post-session ROM report analyzer
OPENROUTER_API_KEY=

# Optional Realtime model overrides
OPENAI_REALTIME_MODEL=gpt-realtime-2025-08-28
OPENAI_REALTIME_VOICE=marin

# CORS — Vision-Agents serve mode reads this via pydantic-settings.
# Default ("*") allows any origin — fine for demo. Tighten by listing exact origins:
# CORS_ALLOW_ORIGINS=["http://localhost:3000","https://ergo-ai.vercel.app"]
# CORS_ALLOW_ORIGINS=*
